// Ad-hoc, account-free configuration for the isolated macOS UI-test host.
// This deliberately clears distribution-only capabilities and local team IDs.
#include "DevelopmentTeam.xcconfig"

CODE_SIGN_STYLE = Automatic
DEVELOPMENT_TEAM =
CODE_SIGN_IDENTITY = -
CODE_SIGN_ENTITLEMENTS =
CODE_SIGNING_ALLOWED = YES
CODE_SIGNING_REQUIRED = YES
ENABLE_APP_SANDBOX = NO
ENABLE_HARDENED_RUNTIME = NO
REGISTER_APP_GROUPS = NO

AGENTLIMITS_APP_GROUP_IDENTIFIER =
AGENTLIMITS_URL_SCHEME = agentlimits-forked-ui-testing

COPY_PHASE_STRIP = NO
DEBUG_INFORMATION_FORMAT = dwarf
ENABLE_TESTABILITY = YES
GCC_OPTIMIZATION_LEVEL = 0
GCC_PREPROCESSOR_DEFINITIONS = DEBUG=1 $(inherited)
ONLY_ACTIVE_ARCH = YES
SWIFT_ACTIVE_COMPILATION_CONDITIONS = DEBUG $(inherited)
SWIFT_OPTIMIZATION_LEVEL = -Onone
